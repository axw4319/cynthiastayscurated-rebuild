---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  schema?: string;
  bodyClass?: string;
  extraHead?: string;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://cynthiastayscurated.com/images/disney-world-cinderella-castle-hero.png',
  ogUrl,
  ogType = 'website',
  twitterTitle,
  twitterDescription,
  schema,
  bodyClass,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#1c3939">

  <!-- Open Graph -->
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={ogUrl || canonical}>
  <meta property="og:title" content={ogTitle || title}>
  <meta property="og:description" content={ogDescription || description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:site_name" content="Cynthia Stays Curated">
  <meta property="og:locale" content="en_US">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={twitterTitle || ogTitle || title}>
  <meta name="twitter:description" content={twitterDescription || ogDescription || description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..900;1,6..96,400..900&family=EB+Garamond:ital,wght@0,400;0,500;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&family=Roboto:wght@100;300;400;500&display=swap" rel="stylesheet">

  <!-- JSON-LD schema (page-specific) -->
  {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Z3JQMEM8T2"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-Z3JQMEM8T2');
  </script>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #f8f6f2;
      --cream-alt: #f4f1ec;
      --teal-dark: #1c3939;
      --teal: #2d6a6a;
      --teal-footer: #2a6363;
      --coral: rgba(225, 140, 132, 0.9);
      --coral-solid: #e18c84;
      --blue-teal: rgba(78, 152, 180, 0.9);
      --gold: #e1a75c;
      --border-gray: #d4d0ca;
      --font-heading: 'Bodoni Moda', 'Bodoni MT', 'Didot', serif;
      --font-display: 'Bodoni Moda', 'Bodoni MT', 'Didot', serif;
      --font-body: 'Montserrat', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--teal-dark);
      background: var(--cream);
      overflow-x: hidden;
    }

    img { display: block; max-width: 100%; }

    /* ===== HEADER ===== */
    .header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 40px;
      background: transparent;
      transition: background 0.35s ease, padding 0.35s ease, height 0.35s ease;
    }

    .header.scrolled {
      background: rgba(28, 57, 57, 0.96);
      backdrop-filter: blur(12px);
      box-shadow: 0 2px 20px rgba(0,0,0,0.15);
      padding: 8px 40px;
    }

    .logo-svg {
      display: block;
      transition: opacity 0.3s ease;
    }

    .logo-svg--circle {
      width: 90px;
      height: auto;
    }

    .logo-svg--wide {
      width: 260px;
      height: auto;
      display: none;
    }

    .header.scrolled .logo-svg--circle { display: none; }
    .header.scrolled .logo-svg--wide { display: block; }

    .menu-btn {
      background: #e1a75c;
      border: none;
      padding: 10px 34px;
      border-radius: 50px;
      font-family: var(--font-body);
      font-size: 23px;
      font-weight: 400;
      color: var(--cream);
      cursor: pointer;
      transition: all 0.3s ease;
      min-width: 145px;
      height: 49px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .menu-btn:hover {
      background: #c9934e;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(225, 167, 92, 0.35);
    }

    /* ===== FOOTER ===== */
    .footer {
      background: var(--teal-footer);
      color: var(--cream);
      padding: 60px 60px 30px;
    }

    .footer-top {
      margin-bottom: 40px;
      padding-bottom: 40px;
      border-bottom: 1px solid rgba(248, 246, 242, 0.18);
    }

    .logo-svg--footer {
      height: 70px;
      width: auto;
    }

    .footer-content {
      display: grid;
      grid-template-columns: auto 1fr 1fr;
      gap: 100px;
      align-items: start;
    }

    .footer-social {
      display: flex;
      gap: 16px;
    }

    .footer-social a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      background: rgba(248, 246, 242, 0.95);
      border-radius: 50%;
      color: var(--teal-footer);
      text-decoration: none;
      transition: all 0.3s;
    }

    .footer-social a:hover {
      background: #fff;
      transform: translateY(-2px);
    }

    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 14px; }

    .footer-links a {
      color: var(--cream);
      text-decoration: none;
      font-size: 16px;
      font-weight: 400;
      opacity: 0.88;
      transition: opacity 0.3s;
    }

    .footer-links a:hover { opacity: 1; }

    .footer-bottom {
      text-align: center;
      padding-top: 30px;
      font-size: 14px;
      opacity: 0.7;
    }

    /* ===== CHAT BUTTON (hidden) ===== */
    .chat-btn { display: none; }

    /* ===== MOBILE MENU ===== */
    .mobile-menu {
      position: fixed;
      inset: 0;
      background: var(--teal-footer);
      z-index: 200;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .mobile-menu.open {
      opacity: 1;
      pointer-events: all;
    }

    .mobile-menu-close {
      position: absolute;
      top: 32px;
      right: 40px;
      background: var(--cream);
      border: none;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      font-size: 22px;
      color: var(--teal-dark);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease;
    }

    .mobile-menu-close:hover { transform: rotate(90deg); }

    .mobile-menu-links {
      list-style: none;
      text-align: center;
      width: 100%;
      max-width: 500px;
      padding: 0 40px;
    }

    .mobile-menu-links li {
      padding: 22px 0;
      border-bottom: 1px solid rgba(248, 246, 242, 0.2);
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .mobile-menu-links li:last-child { border-bottom: none; }

    .mobile-menu.open .mobile-menu-links li {
      opacity: 1;
      transform: translateY(0);
    }

    .mobile-menu.open .mobile-menu-links li:nth-child(1) { transition-delay: 0.15s; }
    .mobile-menu.open .mobile-menu-links li:nth-child(2) { transition-delay: 0.25s; }
    .mobile-menu.open .mobile-menu-links li:nth-child(3) { transition-delay: 0.35s; }

    .mobile-menu-links a {
      font-family: var(--font-heading);
      font-size: clamp(22px, 5vw, 32px);
      font-weight: 400;
      color: var(--cream);
      text-decoration: none;
      transition: opacity 0.3s;
    }

    .mobile-menu-links a:hover { opacity: 0.7; }

    /* ===== SCROLL ANIMATIONS ===== */
    .fade-up {
      opacity: 0;
      transform: translateY(50px);
      transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .fade-up-delay-1 { transition-delay: 0.1s; }
    .fade-up-delay-2 { transition-delay: 0.2s; }
    .fade-up-delay-3 { transition-delay: 0.3s; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .header { padding: 14px 20px; }
      .header.scrolled { padding: 10px 20px; }
      .logo-svg--circle { width: 75px; }
      .logo-svg--wide { width: 190px; }

      .footer { padding: 50px 24px 30px; }
      .footer-content { grid-template-columns: 1fr; gap: 36px; }
      .logo-svg--footer { height: 50px; width: auto; }

      .mobile-menu-close { top: 24px; right: 24px; width: 46px; height: 46px; }
    }

    @media (max-width: 480px) {
      .logo-svg--circle { width: 60px; }
      .logo-svg--wide { width: 160px; }
      .mobile-menu-links { padding: 0 24px; }
      .mobile-menu-links li { padding: 18px 0; }
    }
  </style>
</head>
