---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "Free Travel Quote",
        "url": "https://cynthiastayscurated.com/contact-travel",
        "provider": {
          "@type": "Organization",
          "name": "Cynthia Stays Curated",
          "url": "https://cynthiastayscurated.com/",
          "email": "cynthiastayscurated@gmail.com"
        },
        "serviceType": "Travel Planning",
        "areaServed": { "@type": "Country", "name": "United States" },
        "description": "Cynthia Stays Curated offers complimentary custom travel planning for Disney World, Disneyland, Disney Cruise Line, Universal Orlando, Royal Caribbean, Virgin Voyages, MSC Cruises, Sandals resorts, Florida Keys, Hawaii, national parks, and city getaways. First quote plus two revisions are included at no charge. Proposals delivered within one to three business days.",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD",
          "description": "First travel quote plus up to two revisions are complimentary. A $75 planning fee applies per request for additional revisions (fourth and beyond) or destination changes."
        },
        "availableChannel": {
          "@type": "ServiceChannel",
          "serviceUrl": "https://cynthiastayscurated.com/contact-travel",
          "servicePhone": "",
          "availableLanguage": "English"
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cynthiastayscurated.com/" },
          { "@type": "ListItem", "position": 2, "name": "Free Travel Quote", "item": "https://cynthiastayscurated.com/contact-travel" }
        ]
      },
      {
        "@type": "ContactPage",
        "url": "https://cynthiastayscurated.com/contact-travel",
        "name": "Free Travel Quote Request"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is travel planning with Cynthia Stays Curated really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Travel planning is complimentary for most bookings at Cynthia Stays Curated. Cynthia earns compensation directly from travel suppliers — resorts, cruise lines, and tour operators — not from clients. The first quote plus up to two revisions are included at no charge. A $75 planning fee applies per request for additional revisions or when switching destinations."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to get a travel proposal?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Travel proposals from Cynthia Stays Curated are delivered within one to three business days of receiving a completed quote request form. This form is best suited to travelers who are ready to plan and intend to book within the next seven to ten business days."
        }
      },
      {
        "@type": "Question",
        "name": "What information do I need to request a travel quote?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "To request a travel quote from Cynthia, you will need your destination of interest (Disney, cruise, national park, beach, or city), preferred travel dates, number of travelers (including children's ages for Disney or Universal trips), and a general budget range. Additional preferences such as resort category, cabin type, or accessibility requirements are helpful but not required to start."
        }
      },
      {
        "@type": "Question",
        "name": "Can Cynthia book Disney World trips for families with young children?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Disney World and Disneyland are among Cynthia's most popular destinations for families with young children. She plans itineraries that account for age-appropriate attractions, character dining reservations, stroller logistics, park-hopper strategies, and rest-day pacing to prevent burnout. Travel planning for Disney is free for most bookings."
        }
      },
      {
        "@type": "Question",
        "name": "Does Cynthia book Sandals all-inclusive resorts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Cynthia is an independent travel advisor with specialist knowledge of Sandals all-inclusive resorts in the Caribbean. She can compare resort locations (Jamaica, Barbados, St. Lucia, Bahamas, Antigua, and others), room categories, and dining options, and can access exclusive amenities — including honeymoon and anniversary perks — not available when booking direct."
        }
      },
      {
        "@type": "Question",
        "name": "What cruise lines does Cynthia plan trips for?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cynthia Stays Curated books Royal Caribbean, Virgin Voyages, and MSC Cruises. She helps clients compare itineraries, cabin categories, dining packages, and shore excursion options, and can coordinate pre- and post-cruise hotel and transportation needs."
        }
      },
      {
        "@type": "Question",
        "name": "Can Cynthia plan national park road trips?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Cynthia Stays Curated plans itineraries for Zion National Park, Grand Canyon National Park, and Big Bend National Park. She handles lodging (including in-park accommodations where available), permit timing, activity sequencing, and driving logistics for both first-time and repeat park visitors."
        }
      }
    ]
  }
]);
---

<BaseLayout
  title="Free Travel Quote | Disney, Cruises & More | CSC"
  description="Request a free custom travel quote from Cynthia — a travel advisor specializing in Disney, Universal, cruises, national parks, beach resorts, and more."
  canonical="https://cynthiastayscurated.com/contact-travel"
  ogTitle="Free Travel Quote | Cynthia Stays Curated"
  ogDescription="Request a free, custom travel quote for Disney, cruises, national parks, and more."
  ogImage="https://cynthiastayscurated.com/images/free-travel-quote-hero-beach.jpg"
  twitterTitle="Free Travel Quote | Cynthia Stays Curated"
  twitterDescription="Request a free, custom travel quote."
  schema={schema}
>

  <div class="page-hero">
    <picture><source srcset="/images/free-travel-quote-hero-beach.webp" type="image/webp"><img src="/images/free-travel-quote-hero-beach.jpg" alt="Sandy beach with gentle waves — free travel quote for Disney, cruises, national parks, and beach escapes" loading="eager" fetchpriority="high"></picture>
  </div>

  <div class="content-wrap">
    <div class="info-card fade-up">

      <!-- LEFT COLUMN -->
      <div class="info-left">
        <h1>Free Travel Quote</h1>
        <p class="info-lead">Please fill out the form to let us know more about your travel needs. If you have any questions prior to filling it out please email us at <a href="mailto:cynthiastayscurated@gmail.com">cynthiastayscurated@gmail.com</a></p>

        <div class="info-sections">
          <div class="info-block">
            <h2>Important Notes</h2>
            <p>This form is best for travelers who are ready to move forward and plan to book within the next 7&ndash;10 business days&mdash;so we can give your trip the attention it deserves.</p>
          </div>

          <div class="info-block">
            <h2>Trip Quotes</h2>
            <p>Your first quote + up to 2 revisions are complimentary.</p>
            <p>Additional quotes or revisions (4th and beyond) will incur a $75 planning fee per request.</p>
            <p>(Changes like new dates, switching resorts, or exploring a new destination.)</p>
          </div>

          <div class="info-block">
            <h2>Office Hours</h2>
            <p>Monday&ndash;Thursday: 9:00 AM &ndash; 6:00 PM CST</p>
            <p>Friday: 9:00 AM &ndash; 12:00 PM CST</p>
            <p>Weekends: recharging</p>
          </div>

          <div class="info-block">
            <h2>Turnaround Time</h2>
            <p>Proposals are delivered within 1&ndash;3 business days.</p>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN: full trip quote form -->
      <div class="tq">
        <form id="quoteForm" novalidate>
          <div class="section">
            <div class="section-label">Your information</div>
            <div class="row">
              <div class="field" id="f-fname"><label>First name <span class="req">*</span></label><input type="text" name="firstName" placeholder="Jane" required /><div class="error-msg">Please enter your first name.</div></div>
              <div class="field"><label>Middle name</label><input type="text" name="middleName" placeholder="Lee" /></div>
            </div>
            <div class="field" id="f-lname"><label>Last name <span class="req">*</span></label><input type="text" name="lastName" placeholder="Smith" required /><div class="error-msg">Please enter your last name.</div></div>
            <div class="field" id="f-dob-booker"><label>Date of birth <span class="req">*</span></label><input type="date" name="bookerDOB" required /><div class="error-msg">Please enter your date of birth.</div></div>
            <div class="row">
              <div class="field" id="f-email"><label>Email address <span class="req">*</span></label><input type="email" name="email" placeholder="jane@example.com" required /><div class="error-msg">Please enter a valid email.</div></div>
              <div class="field"><label>Phone number</label><input type="tel" name="phone" placeholder="(555) 000-0000" /></div>
            </div>
            <div class="field" id="f-addr1"><label>Street address <span class="req">*</span></label><input type="text" name="address1" placeholder="123 Main St" required /><div class="error-msg">Please enter your street address.</div></div>
            <div class="field"><label>Apt, suite, unit (optional)</label><input type="text" name="address2" placeholder="Apt 4B" /></div>
            <div class="row-3">
              <div class="field" id="f-city"><label>City <span class="req">*</span></label><input type="text" name="city" placeholder="Dallas" required /><div class="error-msg">Required.</div></div>
              <div class="field" id="f-state"><label>State <span class="req">*</span></label><input type="text" name="state" placeholder="TX" maxlength="2" required /><div class="error-msg">Required.</div></div>
              <div class="field" id="f-zip"><label>ZIP code <span class="req">*</span></label><input type="text" name="zip" placeholder="75201" maxlength="10" required /><div class="error-msg">Required.</div></div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section">
            <div class="section-label">Destination</div>
            <div class="field" id="f-dest">
              <label>Where would you like to go? <span class="req">*</span> <span class="hint">(Select all that apply)</span></label>
              <div class="dest-grid" style="margin-top:8px;">
                <div class="dest-card" data-dest="parks"><span class="dest-icon">&#x1F3A2;</span><span class="dest-name">Theme parks</span><input type="checkbox" name="dest_parks" /></div>
                <div class="dest-card" data-dest="cruise"><span class="dest-icon">&#x1F6A2;</span><span class="dest-name">Cruise</span><input type="checkbox" name="dest_cruise" /></div>
                <div class="dest-card" data-dest="sandals"><span class="dest-icon">&#x1F334;</span><span class="dest-name">Sandals all-inclusive</span><input type="checkbox" name="dest_sandals" /></div>
                <div class="dest-card" data-dest="beach"><span class="dest-icon">&#x1F3D6;&#xFE0F;</span><span class="dest-name">Beach destination</span><input type="checkbox" name="dest_beach" /></div>
                <div class="dest-card" data-dest="national"><span class="dest-icon">&#x26F0;&#xFE0F;</span><span class="dest-name">National park</span><input type="checkbox" name="dest_national" /></div>
                <div class="dest-card" data-dest="city"><span class="dest-icon">&#x1F3D9;&#xFE0F;</span><span class="dest-name">City getaway</span><input type="checkbox" name="dest_city" /></div>
              </div>
              <div class="error-msg" id="dest-err">Please select at least one destination.</div>
            </div>

            <div class="conditional" id="cond-parks">
              <div class="sub-label">Which park(s)? <span class="hint">(Select all that apply)</span></div>
              <div class="sub-checks">
                <label class="sub-check" id="sc-dw"><input type="checkbox" name="park_dw" id="cb-dw" /> Disney World</label>
                <label class="sub-check" id="sc-dl"><input type="checkbox" name="park_dl" id="cb-dl" /> Disneyland</label>
                <label class="sub-check"><input type="checkbox" name="park_dlp" /> Disneyland Paris</label>
                <label class="sub-check"><input type="checkbox" name="park_uor" /> Universal Orlando</label>
                <label class="sub-check"><input type="checkbox" name="park_uoh" /> Universal Hollywood</label>
                <label class="sub-check"><input type="checkbox" name="park_hershey" /> Hersheypark</label>
                <label class="sub-check"><input type="checkbox" name="park_legoca" /> Legoland California</label>
                <label class="sub-check"><input type="checkbox" name="park_legofl" /> Legoland Florida</label>
              </div>
              <div class="field"><label>Other park(s)</label><input type="text" name="parkOther" placeholder="e.g. Busch Gardens, Six Flags, SeaWorld..." /></div>

              <div class="conditional resort-block" id="cond-dw-resort">
                <div class="resort-block-title">Disney World &mdash; hotel preference</div>
                <div class="field"><label>Resort tier</label><select name="dwResortTier" id="dwResortTier"><option value="">Select tier or no preference</option><option value="no_pref">No preference</option><option value="good_neighbor">Good neighbor hotel</option><option value="value">Value resort</option><option value="moderate">Moderate resort</option><option value="deluxe">Deluxe resort</option><option value="deluxe_villa">Deluxe villa</option></select></div>
                <div class="conditional" id="cond-dw-good-neighbor"><div class="field"><label>Good neighbor hotel preference</label><select name="dwGoodNeighbor"><option value="">No preference</option><option>Disney Springs area hotels</option><option>Hotel Plaza Blvd hotels</option></select></div></div>
                <div class="conditional" id="cond-dw-value"><div class="field"><label>Value resort preference</label><select name="dwValueResort"><option value="">No preference</option><option>All-Star Movies</option><option>All-Star Music</option><option>All-Star Sports</option><option>Art of Animation</option><option>Pop Century</option></select></div></div>
                <div class="conditional" id="cond-dw-moderate"><div class="field"><label>Moderate resort preference</label><select name="dwModerateResort"><option value="">No preference</option><option>Caribbean Beach</option><option>Coronado Springs</option><option>Fort Wilderness Cabins</option><option>Port Orleans &mdash; French Quarter</option><option>Port Orleans &mdash; Riverside</option></select></div></div>
                <div class="conditional" id="cond-dw-deluxe"><div class="field"><label>Deluxe resort preference</label><select name="dwDeluxeResort"><option value="">No preference</option><option>Animal Kingdom Lodge</option><option>Beach Club</option><option>BoardWalk Inn</option><option>Contemporary / Bay Lake Tower</option><option>Grand Floridian</option><option>Polynesian Village</option><option>Wilderness Lodge</option><option>Yacht Club</option></select></div></div>
                <div class="conditional" id="cond-dw-deluxe-villa"><div class="field"><label>Deluxe villa preference</label><select name="dwDeluxeVilla"><option value="">No preference</option><option>Animal Kingdom Villas &mdash; Kidani / Jambo</option><option>Bay Lake Tower at Contemporary</option><option>Beach Club Villas</option><option>BoardWalk Villas</option><option>Boulder Ridge / Copper Creek Villas (Wilderness Lodge)</option><option>Grand Floridian Villas</option><option>Old Key West</option><option>Polynesian Villas &amp; Bungalows</option><option>Riviera Resort</option><option>Saratoga Springs</option></select></div></div>
              </div>

              <div class="conditional resort-block" id="cond-dl-resort">
                <div class="resort-block-title">Disneyland &mdash; hotel preference</div>
                <div class="field"><label>Hotel category</label><select name="dlResortTier" id="dlResortTier"><option value="">Select category or no preference</option><option value="no_pref">No preference</option><option value="good_neighbor_dl">Good neighbor hotel</option><option value="disney_owned">Disney-owned hotel</option></select></div>
                <div class="conditional" id="cond-dl-good-neighbor"><div class="field"><label>Good neighbor hotel preference</label><select name="dlGoodNeighbor"><option value="">No preference</option><option>Anaheim Majestic Garden Hotel</option><option>Best Western Plus Park Place Inn</option><option>Cambria Hotel Anaheim Resort</option><option>Camelot Inn &amp; Suites</option><option>Castle Inn &amp; Suites</option></select></div></div>
                <div class="conditional" id="cond-dl-disney-owned"><div class="field"><label>Disney-owned hotel preference</label><select name="dlDisneyOwned"><option value="">No preference</option><option>Disneyland Hotel</option><option>Disney's Grand Californian Hotel &amp; Spa</option><option>Disney's Paradise Pier Hotel</option></select></div></div>
              </div>

              <div class="field" style="margin-top:0.5rem;"><label>Resort stay preference (other parks)</label><select name="parkResort"><option value="">Select preference</option><option>Yes &mdash; on-site resort</option><option>Yes &mdash; off-site hotel</option><option>Not sure</option></select></div>
            </div>

            <div class="conditional" id="cond-cruise">
              <div class="sub-label">Cruise preferences</div>
              <div class="row">
                <div class="field"><label>Preferred cruise line</label><select name="cruiseLine"><option value="">Select or leave open</option><option>Royal Caribbean</option><option>Carnival</option><option>Norwegian</option><option>Disney Cruise Line</option><option>Celebrity</option><option>Princess</option><option>MSC</option><option>No preference</option></select></div>
                <div class="field"><label>Cruise region</label><select name="cruiseRegion"><option value="">Select region</option><option>Caribbean</option><option>Mediterranean</option><option>Alaska</option><option>Bahamas</option><option>Mexico / Pacific</option><option>Not sure</option></select></div>
              </div>
              <div class="field"><label>Cabin preference</label><select name="cabinType"><option value="">Select cabin type</option><option>Interior</option><option>Ocean view</option><option>Balcony</option><option>Suite</option><option>No preference</option></select></div>
              <div class="field"><label>Other cruise preferences</label><input type="text" name="cruiseOther" placeholder="e.g. specific ship, port, itinerary length..." /></div>
            </div>

            <div class="conditional" id="cond-sandals">
              <div class="sub-label">Sandals preferences</div>
              <div class="row">
                <div class="field"><label>Preferred location</label><select name="sandalsLocation"><option value="">Select or leave open</option><option>Jamaica</option><option>Bahamas</option><option>Barbados</option><option>St. Lucia</option><option>Antigua</option><option>Turks &amp; Caicos</option><option>Grenada</option><option>No preference</option></select></div>
                <div class="field"><label>Room category</label><select name="sandalsRoom"><option value="">Select preference</option><option>Garden / Beachside room</option><option>Oceanfront room</option><option>Butler suite</option><option>Overwater bungalow</option><option>No preference</option></select></div>
              </div>
            </div>

            <div class="conditional" id="cond-beach">
              <div class="sub-label">Beach destination preferences</div>
              <div class="sub-checks">
                <label class="sub-check"><input type="checkbox" name="beach_cancun" /> Cancun</label>
                <label class="sub-check"><input type="checkbox" name="beach_punta" /> Punta Cana</label>
                <label class="sub-check"><input type="checkbox" name="beach_cabo" /> Los Cabos</label>
                <label class="sub-check"><input type="checkbox" name="beach_riviera" /> Riviera Maya</label>
                <label class="sub-check"><input type="checkbox" name="beach_bahamas" /> Bahamas</label>
                <label class="sub-check"><input type="checkbox" name="beach_hawaii" /> Hawaii</label>
                <label class="sub-check"><input type="checkbox" name="beach_maldives" /> Maldives</label>
              </div>
              <div class="field"><label>Other beach destination(s)</label><input type="text" name="beachOther" placeholder="e.g. Turks &amp; Caicos, Bali, Costa Rica..." /></div>
            </div>

            <div class="conditional" id="cond-national">
              <div class="sub-label">National park preferences</div>
              <div class="sub-checks">
                <label class="sub-check"><input type="checkbox" name="np_gc" /> Grand Canyon</label>
                <label class="sub-check"><input type="checkbox" name="np_ys" /> Yellowstone</label>
                <label class="sub-check"><input type="checkbox" name="np_zion" /> Zion</label>
                <label class="sub-check"><input type="checkbox" name="np_yos" /> Yosemite</label>
                <label class="sub-check"><input type="checkbox" name="np_bryce" /> Bryce Canyon</label>
                <label class="sub-check"><input type="checkbox" name="np_glacier" /> Glacier</label>
                <label class="sub-check"><input type="checkbox" name="np_smoky" /> Great Smoky Mountains</label>
                <label class="sub-check"><input type="checkbox" name="np_rocky" /> Rocky Mountain</label>
              </div>
              <div class="field"><label>Other park(s)</label><input type="text" name="nationalOther" placeholder="e.g. Arches, Acadia, Olympic..." /></div>
              <div class="field"><label>Lodging preference</label><select name="nationalLodging"><option value="">Select preference</option><option>Park lodge / in-park hotel</option><option>Nearby hotel / resort</option><option>Camping / glamping</option><option>No preference</option></select></div>
            </div>

            <div class="conditional" id="cond-city">
              <div class="sub-label">Which city or cities? <span class="hint">(Select all that apply)</span></div>
              <div class="sub-checks">
                <label class="sub-check"><input type="checkbox" name="city_nashville" /> Nashville</label>
                <label class="sub-check"><input type="checkbox" name="city_scottsdale" /> Scottsdale</label>
                <label class="sub-check"><input type="checkbox" name="city_nyc" /> New York City</label>
                <label class="sub-check"><input type="checkbox" name="city_chicago" /> Chicago</label>
                <label class="sub-check"><input type="checkbox" name="city_nola" /> New Orleans</label>
                <label class="sub-check"><input type="checkbox" name="city_vegas" /> Las Vegas</label>
                <label class="sub-check"><input type="checkbox" name="city_savannah" /> Savannah</label>
                <label class="sub-check"><input type="checkbox" name="city_charleston" /> Charleston</label>
                <label class="sub-check"><input type="checkbox" name="city_denver" /> Denver</label>
                <label class="sub-check"><input type="checkbox" name="city_seattle" /> Seattle</label>
              </div>
              <div class="field"><label>Other city or cities</label><input type="text" name="cityOther" placeholder="e.g. Austin, San Francisco, Miami..." /></div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section">
            <div class="section-label">Travel details</div>
            <div class="row">
              <div class="field" id="f-depart"><label>Departure date <span class="req">*</span></label><input type="date" name="departDate" required /><div class="error-msg">Please select a departure date.</div></div>
              <div class="field"><label>Return date</label><input type="date" name="returnDate" /></div>
            </div>
            <div class="field"><label>How flexible are your dates?</label><select name="flexibility"><option value="">Select flexibility</option><option>Exact dates only</option><option>+/- 1&ndash;2 days</option><option>+/- 1 week</option><option>Very flexible &mdash; show me best options</option></select></div>
            <div class="row">
              <div class="field" id="f-depart-city"><label>Departing from <span class="req">*</span></label><input type="text" name="departCity" placeholder="City or airport" required /><div class="error-msg">Please enter your departure city.</div></div>
              <div class="field"><label>Trip length (nights)</label><input type="number" name="nights" min="1" max="60" placeholder="e.g. 7" /></div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section">
            <div class="section-label">Travelers</div>
            <div class="row" style="margin-bottom:1.25rem;">
              <div class="field" id="f-adults" style="margin-bottom:0;"><label>Adults (18+) <span class="req">*</span></label><input type="number" name="adultCount" min="1" max="20" value="1" placeholder="1" id="adultCount" required /><div class="error-msg">At least 1 adult required.</div></div>
              <div class="field" style="margin-bottom:0;"><label>Children (under 18)</label><input type="number" name="childCount" min="0" max="20" placeholder="0" id="childCount" /></div>
            </div>
            <div class="field"><label>Infants (under 2)</label><input type="number" name="infantCount" min="0" max="10" placeholder="0" id="infantCount" /></div>
            <div id="travelerProfiles"></div>
            <div class="field" style="margin-top:0.5rem;"><label>Celebrating anything special?</label><select name="occasion"><option value="">Select occasion (optional)</option><option>Honeymoon</option><option>Anniversary</option><option>Birthday</option><option>Family reunion</option><option>Graduation</option><option>Babymoon</option><option>Just a vacation</option><option>Other</option></select></div>
          </div>

          <div class="divider"></div>

          <div class="section">
            <div class="section-label">Budget &amp; preferences</div>
            <div class="row">
              <div class="field"><label>Estimated budget (per person)</label><select name="budget"><option value="">Select budget range</option><option>Under $1,000</option><option>$1,000 &ndash; $2,500</option><option>$2,500 &ndash; $5,000</option><option>$5,000 &ndash; $10,000</option><option>$10,000+</option><option>Prefer not to say</option></select></div>
              <div class="field"><label>Travel insurance interest</label><select name="insurance"><option value="">Select preference</option><option>Yes &mdash; please include</option><option>No &mdash; not interested</option><option>I'd like more info</option></select></div>
            </div>
            <div class="field"><label>How did you hear about us?</label><select name="referral"><option value="">Select source</option><option>Friend or family referral</option><option>Google search</option><option>Instagram / Facebook</option><option>Returning client</option><option>Other</option></select></div>
          </div>

          <div class="divider"></div>

          <div class="section">
            <div class="section-label">Anything else?</div>
            <div class="field"><label>Additional notes, requests, or questions</label><textarea name="notes" rows="4" placeholder="Dietary restrictions, accessibility needs, must-have experiences, past travel, etc."></textarea></div>
          </div>

          <div class="submit-row">
            <button type="submit" class="submit-btn" id="submitBtn">Submit request</button>
          </div>

          <div class="submit-error" id="submitError">Something went wrong submitting your request. Please try again or email us directly.</div>
        </form>

        <div class="success-box" id="successBox">
          <p><strong>Thank you!</strong></p>
          <p style="margin-top:8px;">If we have additional questions, we'll reach out within 1 business day.<br>Your customized quote will be delivered within 1&ndash;3 business days.</p>
        </div>
      </div>

    </div>
  </div>

</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    height: 460px;
    overflow: hidden;
    margin-top: 0;
  }

  .page-hero picture { display: contents; }
  .page-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.1);
