---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy",
  "url": "https://cynthiastayscurated.com/privacy-policy",
  "description": "Privacy policy for Cynthia Stays Curated.",
  "publisher": {
    "@type": "Organization",
    "name": "Cynthia Stays Curated",
    "url": "https://cynthiastayscurated.com"
  }
});
---

<BaseLayout
  title="Privacy Policy | Cynthia Stays Curated"
  description="How Cynthia Stays Curated collects, uses, and protects your information when you visit our website, request a travel quote, or book a design consultation."
  canonical="https://cynthiastayscurated.com/privacy-policy"
  ogTitle="Privacy Policy | Cynthia Stays Curated"
  ogDescription="How Cynthia Stays Curated collects, uses, and protects your information when you visit, request a travel quote, or book a design consultation."
  ogImage="https://cynthiastayscurated.com/images/cynthia-stays-curated-logo-horizontal.png"
  schema={schema}
>

  <main class="legal-page">
    <h1>Privacy Policy</h1>
    <p class="updated">Last updated: April 11, 2026</p>

    <p>This Privacy Policy describes how Cynthia Stays Curated ("we," "us," or "our") collects, uses, and shares information about you when you visit our website, request a travel quote, or book an interior design consultation.</p>

    <h2>Information We Collect</h2>
    <p>We collect information you provide directly to us, such as when you:</p>
    <ul>
      <li>Submit the Free Travel Quote form (name, email, phone, travel needs)</li>
      <li>Submit the Free Design Consultation form (name, email, phone, property details, budget)</li>
      <li>Subscribe to our newsletter</li>
      <li>Contact us by email or social media</li>
    </ul>
    <p>We may also automatically collect limited technical information through standard website analytics, including your IP address, browser type, device type, pages visited, and the time and date of your visit.</p>

    <h2>How We Use Your Information</h2>
    <p>We use the information we collect to:</p>
    <ul>
      <li>Respond to your travel quote or design consultation request</li>
      <li>Plan, book, and manage travel on your behalf</li>
      <li>Send project updates, follow-ups, and service-related communication</li>
      <li>Improve our website and services</li>
      <li>Send newsletters and promotional emails (only if you've opted in — you can unsubscribe at any time)</li>
    </ul>

    <h2>How We Share Your Information</h2>
    <p>We do not sell your personal information. We may share your information with:</p>
    <ul>
      <li><strong>Travel suppliers</strong> (resorts, cruise lines, tour operators) to complete bookings on your behalf</li>
      <li><strong>Service providers</strong> that help us operate our business (email, analytics, hosting)</li>
      <li><strong>Legal authorities</strong> when required by law, subpoena, or to protect our rights</li>
    </ul>
    <p>All third parties are required to protect your information and use it only for the purpose it was shared.</p>

    <h2>Cookies and Analytics</h2>
    <p>Our website uses cookies and similar technologies to understand how visitors use the site and to improve your experience. You can control cookies through your browser settings. Disabling cookies may affect some site functionality.</p>

    <h2>Data Retention</h2>
    <p>We retain your information for as long as needed to provide our services, comply with legal obligations, resolve disputes, and enforce our agreements. You can request that we delete your information at any time by emailing us.</p>

    <h2>Your Rights</h2>
    <p>Depending on where you live, you may have the right to:</p>
    <ul>
      <li>Access the personal information we hold about you</li>
      <li>Request correction of inaccurate information</li>
      <li>Request deletion of your information</li>
      <li>Opt out of marketing communications</li>
      <li>Withdraw consent at any time</li>
    </ul>
    <p>To exercise any of these rights, please contact us at <a href="mailto:cynthiastayscurated@gmail.com">cynthiastayscurated@gmail.com</a>.</p>

    <h2>Children's Privacy</h2>
    <p>Our website is not intended for children under 13, and we do not knowingly collect personal information from children under 13. If you believe we have collected information from a child, please contact us and we will delete it.</p>

    <h2>Changes to This Policy</h2>
    <p>We may update this Privacy Policy from time to time. When we do, we will update the "Last updated" date at the top of this page. Significant changes will be communicated through the website or by email if you are a subscriber.</p>

    <h2>Contact Us</h2>
    <p>If you have questions about this Privacy Policy or how we handle your information, please contact us at:</p>
    <p><strong>Email:</strong> <a href="mailto:cynthiastayscurated@gmail.com">cynthiastayscurated@gmail.com</a></p>
  </main>

</BaseLayout>

<style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #f8f6f2;
      --cream-alt: #f4f1ec;
      --teal-dark: #1c3939;
      --teal: #2d6a6a;
      --teal-footer: #2a6363;
      --coral-solid: #e18c84;
      --gold: #e1a75c;
      --border-gray: #d4d0ca;
      --font-heading: 'Bodoni Moda', 'Bodoni MT', 'Didot', serif;
      --font-body: 'Montserrat', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--teal-dark); background: var(--cream); overflow-x: hidden; line-height: 1.7; }
    img { display: block; max-width: 100%; }
    a { color: var(--teal); text-decoration: underline; text-underline-offset: 3px; }
    a:hover { color: var(--teal-dark); }

    .header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 20px 40px; background: transparent; transition: all 0.35s ease; }
    .header.scrolled { background: rgba(28, 57, 57, 0.96); backdrop-filter: blur(12px); box-shadow: 0 2px 20px rgba(0,0,0,0.15); padding: 8px 40px; }
    .header-logo { height: auto; transition: opacity 0.3s ease; }
    .header-logo--stacked { width: 180px; }
    .header-logo--horizontal { width: 280px; display: none; }
    .header.scrolled .header-logo--stacked { display: none; }
    .header.scrolled .header-logo--horizontal { display: block; }
    .menu-btn { background: #e1a75c; border: none; padding: 10px 34px; border-radius: 50px; font-family: var(--font-body); font-size: 23px; font-weight: 400; color: var(--cream); cursor: pointer; transition: all 0.3s ease; min-width: 145px; height: 49px; display: flex; align-items: center; justify-content: center; }
    .menu-btn:hover { background: #c9934e; transform: translateY(-1px); }

    .legal-page {
      max-width: 820px;
      margin: 0 auto;
      padding: 180px 40px 100px;
    }

    .legal-page h1 {
      font-family: var(--font-heading);
      font-size: 72px;
      font-weight: 400;
      letter-spacing: -2px;
      line-height: 1;
      margin-bottom: 40px;
      color: var(--teal-dark);
    }

    .legal-page .updated {
      font-size: 13px;
      color: #888;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 50px;
      padding-bottom: 30px;
      border-bottom: 1px solid var(--border-gray);
    }

    .legal-page h2 {
      font-family: var(--font-heading);
      font-size: 36px;
      font-weight: 500;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin: 50px 0 18px;
      color: var(--teal-dark);
    }

    .legal-page h3 {
      font-family: var(--font-heading);
      font-size: 24px;
      font-weight: 500;
      margin: 30px 0 12px;
      color: var(--teal-dark);
    }

    .legal-page p {
      font-size: 16px;
      line-height: 1.75;
      color: var(--teal-dark);
      margin-bottom: 18px;
    }

    .legal-page ul {
      padding-left: 24px;
      margin-bottom: 24px;
    }

    .legal-page li {
      font-size: 16px;
      line-height: 1.75;
      margin-bottom: 8px;
      color: var(--teal-dark);
    }

    .legal-page strong { font-weight: 600; color: var(--teal-dark); }

    .footer { background: var(--teal-footer); color: var(--cream); padding: 60px 60px 30px; }
    .footer-top { margin-bottom: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(248, 246, 242, 0.18); }
    .footer-logo-img { height: 70px; width: auto; }
    .footer-content { display: grid; grid-template-columns: auto 1fr 1fr; gap: 100px; align-items: start; max-width: 1400px; margin: 0 auto; }
    .footer-social { display: flex; gap: 16px; justify-content: flex-start; }
    .footer-social a { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; background: rgba(248, 246, 242, 0.95); border-radius: 50%; color: var(--teal-footer); text-decoration: none; transition: all 0.3s; }
    .footer-social a:hover { background: #fff; transform: translateY(-2px); }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 14px; }
    .footer-links a { color: var(--cream); text-decoration: none; font-size: 16px; opacity: 0.88; transition: opacity 0.3s; }
    .footer-links a:hover { opacity: 1; }
    .footer-bottom { text-align: center; padding-top: 30px; font-size: 14px; opacity: 0.7; }

    .mobile-menu { position: fixed; inset: 0; background: var(--teal-footer); z-index: 200; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
    .mobile-menu.open { opacity: 1; pointer-events: all; }
    .mobile-menu-close { position: absolute; top: 32px; right: 40px; background: var(--cream); border: none; width: 52px; height: 52px; border-radius: 50%; font-size: 22px; color: var(--teal-dark); cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .mobile-menu-links { list-style: none; text-align: center; }
    .mobile-menu-links li { padding: 22px 0; border-bottom: 1px solid rgba(248, 246, 242, 0.2); opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .mobile-menu-links li:last-child { border-bottom: none; }
    .mobile-menu.open .mobile-menu-links li { opacity: 1; transform: translateY(0); }
    .mobile-menu.open .mobile-menu-links li:nth-child(1) { transition-delay: 0.15s; }
    .mobile-menu.open .mobile-menu-links li:nth-child(2) { transition-delay: 0.25s; }
    .mobile-menu.open .mobile-menu-links li:nth-child(3) { transition-delay: 0.35s; }
    .mobile-menu.open .mobile-menu-links li:nth-child(4) { transition-delay: 0.45s; }
    .mobile-menu-links a { font-family: var(--font-heading); font-size: clamp(22px, 5vw, 32px); color: var(--cream); text-decoration: none; }

    @media (max-width: 768px) {
      .header { padding: 14px 20px; }
      .header.scrolled { padding: 10px 20px; }
      .header-logo--stacked { width: 140px; }
      .header.scrolled .header-logo--horizontal { width: 200px; }
      .header-logo--horizontal { width: 220px; }
      .menu-btn { padding: 10px 26px; font-size: 17px; min-width: 120px; height: 44px; }

      .legal-page { padding: 130px 24px 60px; }
      .legal-page h1 { font-size: 48px; letter-spacing: -1px; }
      .legal-page h2 { font-size: 28px; margin: 36px 0 14px; }
      .legal-page h3 { font-size: 20px; }

      .footer { padding: 50px 24px 30px; }
      .footer-content { grid-template-columns: 1fr; gap: 36px; }
      .footer-logo-img { height: 55px; }
    }
  
    @media (max-width: 480px) {
      .mobile-menu-links { padding: 0 24px; }
      .mobile-menu-links li { padding: 18px 0; }
    }
  
    @media (max-width: 600px) {
      .header-logo--stacked { width: 120px; }
      .legal-page { padding: 140px 20px 60px; }
      .legal-page h1 { font-size: 36px; letter-spacing: -0.5px; }
    }
</style>
