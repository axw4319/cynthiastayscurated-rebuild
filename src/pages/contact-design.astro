---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemaRaw = `[{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "name": "Short-Term Rental Interior Design",
        "url": "https://cynthiastayscurated.com/contact-design",
        "provider": {
          "@type": "Organization",
          "name": "Cynthia Stays Curated",
          "url": "https://cynthiastayscurated.com/"
        },
        "serviceType": "Interior Design",
        "areaServed": { "@type": "Country", "name": "United States" },
        "description": "Short-term rental interior design for new properties and refreshes. Virtual design with sourced product links or full ordering and installation management.",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Design Packages",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New Property Virtual Design with Links" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New Property Virtual Design + Ordering" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Property Refresh Virtual Design with Links" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Property Refresh + Ordering" } }
          ]
        }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cynthiastayscurated.com/" },
          { "@type": "ListItem", "position": 2, "name": "Free Design Consultation", "item": "https://cynthiastayscurated.com/contact-design" }
        ]
      },
      {
        "@type": "ContactPage",
        "url": "https://cynthiastayscurated.com/contact-design",
        "name": "Free Interior Design Consultation"
      }
    ]
  },{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What design services do you offer for short-term rentals?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Four packages: New Property Virtual Design with Links, New Property Virtual Design + Ordering, Property Refresh Virtual Design with Links, and Property Refresh + Ordering."
        }
      },
      {
        "@type": "Question",
        "name": "Is the design consultation really free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The initial consultation is complimentary so we can review your property, goals, and budget before you commit to a design package."
        }
      },
      {
        "@type": "Question",
        "name": "Do you work remotely or only locally?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All design services are offered virtually, which means we can work with short-term rental hosts anywhere in the United States."
        }
      }
    ]
  }]`;
---

<BaseLayout
  title="Free Interior Design Consultation | Cynthia Stays Curated"
  description="Book a free interior design consultation for new short-term rentals or property refreshes. Virtual design with sourced links or full ordering included."
  canonical="https://cynthiastayscurated.com/contact-design"
  ogTitle="Free Short-Term Rental Design Consultation"
  ogDescription="New property or refresh design for short-term rentals. Virtual packages with sourced links or full ordering."
  ogImage="https://cynthiastayscurated.com/images/interior-design-consultation-hero.jpg"
  schema={schemaRaw}
>

  <div class="page-hero">
    <picture><source srcset="images/interior-design-consultation-hero.webp" type="image/webp"><img src="images/interior-design-consultation-hero.jpg" alt="Interior of a beautifully designed short-term rental living room — free design consultation for rental hosts" loading="eager" fetchpriority="high"></picture>
  </div>

  <div class="form-section">
